*.bak

# E2E Testing
e2e/.auth/
e2e/.env.e2e
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/

# --- Étape 4: large media & test artifacts (DUP-05, OPT-08) ---
# Large media must live in object storage (Vercel Blob / R2 / Supabase Storage),
# never in Git. Tracking 35MB+ binaries bloats every clone and CI checkout.
*.mp4
*.mov
*.webm
public/demo-video.mp4

# Playwright artifacts (regenerated on every CI run)
playwright-report/
test-results/

# Tooling caches
.turbo/
.claude/
