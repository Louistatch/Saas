# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service role key — server-only, bypasses RLS.
# Copy from Supabase Dashboard → Project Settings → API → service_role key.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Server-only — used to encrypt integration secrets at rest (AES-256-GCM).
# Generate with:  openssl rand -base64 32
INTEGRATION_SECRET_KEY=

# KoboCollect webhook secret — REQUIRED for webhook endpoint security.
# Generate with:  openssl rand -hex 32
KOBO_WEBHOOK_SECRET=

# Sentry — error tracking (optional, app works without it)
# Create a project at https://sentry.io and paste the DSN here.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Optional: enable verbose client logs in production builds.
# NEXT_PUBLIC_DEBUG=1

# ─── AgriTogo AI Integration ──────────────────────────────────────────────────

# ── DeepSeek (chat + voice responses) — REQUIS ────────────────────────────────
# Obtenez vos clés sur https://platform.deepseek.com/api_keys
# Ajoutez plusieurs clés pour la rotation automatique (évite les erreurs 429) :
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_API_KEY_1=sk-...
# DEEPSEEK_API_KEY_2=sk-...
# DEEPSEEK_API_KEY_3=sk-...

# Modèle DeepSeek utilisé (défaut: deepseek-chat = DeepSeek-V3)
# Options: deepseek-chat (rapide, économique) | deepseek-reasoner (R1, plus approfondi)
# DEEPSEEK_MODEL=deepseek-chat

# ── Gemini (vision phytosanitaire + transcription vocale) — REQUIS si vision/voice ─
# DeepSeek ne supporte pas encore les images/audio. Gemini reste nécessaire pour :
#   - /api/ai/vision  → analyse de photos de cultures
#   - /api/ai/voice   → transcription de l'audio (étape 1), DeepSeek répond (étape 2)
# Obtenez des clés sur https://aistudio.google.com/app/apikey (tier gratuit suffisant)
GEMINI_API_KEY=AIza...
# GEMINI_API_KEY_1=AIza...
# GEMINI_API_KEY_2=AIza...

# AgriTogo API — moteur multi-agent (AgentScope + DeepSeek) sur Railway.
# Si non configuré, fallback direct sur DeepSeek (niveau 3b).
AGRITOGO_API_URL=https://api.agritogo.tg

# ─── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Optional but strongly recommended in production to persist rate limits
# across serverless function instances (prevents brute-force on /verify).
# Create a Redis database at https://console.upstash.com and copy the values.
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Payments (Orange Money) ──────────────────────────────────────────────────
# Required to accept Orange Money payments via /api/payments/initiate.
ORANGE_MONEY_API_KEY=

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Secret used to authenticate the /api/cron/notifications endpoint.
# Generate with:  openssl rand -hex 32
CRON_SECRET=

# ─── App URL (used in payment redirect and link generation) ───────────────────
NEXT_PUBLIC_APP_URL=https://www.faitierehub.com

# ─── Haroo (optional) ──────────────────────────────────────────────────────────
# Public URL of the Haroo platform, linked from the marketing pages
# (signup/login for ouvriers, acheteurs, agronomes). Defaults to https://haroo.tg.
# NEXT_PUBLIC_HAROO_URL=https://haroo.tg
